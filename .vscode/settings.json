{
    // 彻底禁用微软自带的 C/C++ 插件的 IntelliSense，防止它和 clangd 打架抢资源
    "C_Cpp.intelliSenseEngine": "disabled",
    "clangd.path": "/usr/bin/clangd-15",
    "clangd.arguments": [
        "--compile-commands-dir=${workspaceFolder}/build",
        "--background-index",
        "-j=2",
        "--header-insertion=iwyu",
        "--clang-tidy",
        // "--query-driver=**"
    ],
    // "cmake.configureArgs": [
    //     "-DCMAKE_PREFIX_PATH=/home/jayzhang/Qt/6.11.0/gcc_64"
    // ]
}