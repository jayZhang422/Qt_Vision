# ==========================================
# 1. CMake 编译生成的缓存和二进制文件 (绝对不能提交！)
# ==========================================
build/
bin/
lib/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.cmake

# ==========================================
# 2. Clangd 相关的缓存文件 (自动生成的，不需要提交)
# ==========================================
compile_commands.json
.cache/
.clangd/

# ==========================================
# 3. VS Code 配置文件
# ==========================================
# 通常我们不提交整个 .vscode 文件夹，因为里面包含你个人的本地绝对路径
.vscode/*
# 但是，我们希望把代码风格和核心设置保留下来共享给队友，所以用 "!" 把它们"救"回来
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# ==========================================
# 4. 操作系统产生的垃圾文件 (防队友血压升高必备)
# ==========================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# ==========================================
# 5. C++ 运行时产生的崩溃日志或临时文件
# ==========================================
*.log
core
core.*